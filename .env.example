TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
TARGET_TZ=Asia/Singapore

# Access control
ALLOWED_CHAT_IDS=replace_me

# Telegram runtime mode: polling, webhook, or disabled.
TELEGRAM_MODE=polling
TELEGRAM_POLLING=true

# Webhook mode settings
TELEGRAM_WEBHOOK_URL=https://your-domain.example/telegram/webhook
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace_me

# Telegram retry settings
TELEGRAM_SEND_RETRY_ATTEMPTS=2
TELEGRAM_SEND_RETRY_DELAY_SECONDS=2

# Calendar behavior
SCRAPE_DELAY_MINUTES=2
RESULT_RETRY_ATTEMPTS=60
RESULT_RETRY_DELAY_SECONDS=30
WARNING_MINUTES=10
SUMMARY_HOUR=6
RESCHEDULE_INTERVAL_MINUTES=30

# Optional filters. Leave blank to include all values.
SUMMARY_CURRENCIES=
SUMMARY_IMPACTS=
ALERT_CURRENCIES=USD,EUR,GBP,JPY
ALERT_IMPACTS=High,Medium
